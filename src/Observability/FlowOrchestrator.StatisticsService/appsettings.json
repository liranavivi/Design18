{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "StatisticsService": {
    "ServiceId": "StatisticsService",
    "ServiceType": "StatisticsService",
    "RetentionPeriodDays": 30,
    "ArchivalIntervalDays": 7,
    "CollectionIntervalMs": 1000,
    "DetailedStatisticsEnabled": true,
    "HistoricalDataEnabled": true
  },
  "OpenTelemetry": {
    "ServiceName": "FlowOrchestrator.StatisticsService",
    "ServiceVersion": "1.0.0",
    "ServiceInstanceId": "instance-001",
    "OtlpEndpoint": "http://localhost:4317",
    "EnableConsoleExporter": true,
    "EnableOtlpExporter": true,
    "EnableMetrics": true,
    "EnableTracing": true,
    "EnableLogging": true,
    "MetricsCollectionIntervalMs": 1000,
    "MetricsExportIntervalMs": 5000,
    "TracingSamplingRate": 1.0
  }
}
