{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.Hosting.Lifetime": "Information",
      "FlowOrchestrator.Processing.Json": "Debug"
    }
  },
  "JsonProcessor": {
    "ServiceId": "JSON-PROCESSOR-DEV-001",
    "ServiceType": "JsonProcessor",
    "MaxDepth": 128,
    "MaxStringLength": 2097152,
    "AllowComments": true,
    "AllowTrailingCommas": true,
    "WriteIndented": true,
    "IgnoreNullValues": false,
    "UseCamelCase": true,
    "OperationTimeoutSeconds": 120,
    "MaxRetryCount": 5,
    "RetryDelayMilliseconds": 500
  }
}
